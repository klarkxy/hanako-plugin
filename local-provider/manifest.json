{
  "manifestVersion": 1,
  "id": "local-provider",
  "name": "Local Provider",
  "version": "0.1.0",
  "description": "Connect LM Studio as a local chat provider and expose configurable local media runtimes for image, video, and speech.",
  "author": {
    "name": "klarkxy"
  },
  "license": "SATA-2.0",
  "minAppVersion": "0.171.3",
  "trust": "full-access",
  "homepage": "https://github.com/klarkxy/hanako-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/klarkxy/hanako-plugin.git"
  },
  "categories": [
    "providers",
    "local",
    "media"
  ],
  "keywords": [
    "local",
    "lm-studio",
    "provider",
    "image",
    "video",
    "speech",
    "cli"
  ],
  "contributes": {
    "configuration": {
      "properties": {
        "runtimes": {
          "type": "object",
          "title": "Configured local runtimes",
          "default": {}
        }
      }
    }
  }
}